local function CreateSlider(name, pos, min, max, default, callback)
    local frame = Instance.new("Frame", main)
    frame.Size = UDim2.new(0.92, 0, 0, 55)
    frame.Position = pos
    frame.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0.4, 0)
    label.Text = name .. ": " .. default
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 13
    label.BackgroundTransparency = 1
    local bar = Instance.new("Frame", frame)
    bar.Size = UDim2.new(0.85, 0, 0, 6)
    bar.Position = UDim2.new(0.075, 0, 0.7, 0)
    bar.BackgroundColor3 = Color3.fromRGB(65, 65, 90)
    local fill = Instance.new("Frame", bar)
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(110, 110, 255)
    local knob = Instance.new("TextButton", bar)
    knob.Size = UDim2.new(0, 18, 0, 20)
    knob.Position = UDim2.new((default - min) / (max - min), -9, 0.5, -10)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.Text = ""
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local dragging = false
    knob.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    RunService.RenderStepped:Connect(function() 
        if dragging then 
            local input = UserInputService:GetMouseLocation()
            local percent = math.clamp((input.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            local value = math.floor(min + (max - min) * percent)
            knob.Position = UDim2.new(percent, -9, 0.5, -10)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            label.Text = name .. ": " .. value
            callback(value)
        end 
    end)
end

