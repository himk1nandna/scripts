local function CreateToggle(parent, name, pos, callback, default)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.92, 0, 0, 45)
    btn.Position = pos
    btn.Text = name .. ": " .. (default and "ON" or "OFF")
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 16
    btn.BackgroundColor3 = default and Color3.fromRGB(70, 160, 70) or Color3.fromRGB(50, 50, 70)
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
    local state = default or false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name .. ": " .. (state and "ON" or "OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(70, 160, 70) or Color3.fromRGB(50, 50, 70)
        callback(state)
    end)
    return btn
end

