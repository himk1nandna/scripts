-- [[ HELPERS ]] --
local function GetChestType(chest)
    local name = chest.Name
    if string.find(name, "Giant") then return "Giant" end
    if string.find(name, "Huge") then return "Huge" end
    if string.find(name, "Chest") then return "Normal" end
    return "Special"
end

local function GetClosestTarget()
    local character = LocalPlayer.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    if _G.AutoCollectChests then
        local chestFolder = workspace:FindFirstChild("ChestFolder")
        if chestFolder then
            local closestChest = nil
            local chestDist = math.huge
            for _, chest in ipairs(chestFolder:GetChildren()) do
                local pos = (chest:IsA("Model") and chest:GetPivot().Position) or (chest:IsA("BasePart") and chest.Position)
                if pos then
                    local d = (root.Position - pos).Magnitude
                    local cType = GetChestType(chest)
                    if _G.ChestFilters[cType] and d < chestDist then
                        chestDist = d
                        closestChest = chest
                    end
                end
            end
            if closestChest then return closestChest end
        end
    end
    return nil
end

-- [[ UNLOAD ]] --
local function Unload()
    _G.AutoFarm = false
    _G.AutoCollectChests = false
    _G.WalkSpeedValue = 16
    for _, conn in ipairs(Connections) do
        if conn and conn.Disconnect then conn:Disconnect() end
    end
    local gui = CoreGui:FindFirstChild("CutTreesGUI")
    if gui then gui:Destroy() end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then 
        hum.WalkSpeed = 16
        hum:Move(Vector3.new(0,0,0)) 
    end
end

-- [[ PERSISTENT SPEED LOOP ]] --
table.insert(Connections, RunService.Heartbeat:Connect(function()
    local character = LocalPlayer.Character
    local hum = character and character:FindFirstChild("Humanoid")
    if hum then
        hum.WalkSpeed = _G.WalkSpeedValue
    end
end))

-- [[ MOVEMENT LOOP ]] --
task.spawn(function()
    while true do
        local character = LocalPlayer.Character
        local hum = character and character:FindFirstChild("Humanoid")
        local root = character and character:FindFirstChild("HumanoidRootPart")
        
        if hum and root and _G.AutoCollectChests then
            local target = GetClosestTarget()
            if target then
                local pos = (target:IsA("Model") and target:GetPivot().Position) or target.Position
                hum:MoveTo(pos)
                
                local dist = (root.Position - pos).Magnitude
                if dist < 8 then
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    task.wait(0.1)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                    task.wait(0.2)
                end
            else
                hum:Move(Vector3.new(0,0,0))
            end
        end
        task.wait(0.1)
    end
end)

-- [[ ULTRA BURST FARM ]] --
task.spawn(function()
    while true do
        if _G.AutoFarm then
            local character = LocalPlayer.Character
            local root = character and character:FindFirstChild("HumanoidRootPart")
            if root and _G.AutoFarm then
                if _G.FarmMode == "Click" then
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                    task.wait(0.01)
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                    task.wait(CLICK_SPEED)
                else
                    local treesFolder = workspace:FindFirstChild("TreesFolder")
                    if treesFolder then
                        local rootPos = root.Position
                        local potentialTargets = {}
                        for _, tree in ipairs(treesFolder:GetChildren()) do
                            local hitpart = tree:FindFirstChild("Hitpart") or tree.PrimaryPart
                            if hitpart then
                                table.insert(potentialTargets, {tree = tree, dist = (rootPos - hitpart.Position).Magnitude})
                            end
                        end
                        table.sort(potentialTargets, function(a, b) return a.dist < b.dist end)
                        
                        for i = 1, math.min(#potentialTargets, MAX_CONCURRENT_TREES) do
                            if not _G.AutoFarm or _G.FarmMode ~= "Remote" then break end
                            local tree = potentialTargets[i].tree
                            for b = 1, math.min(_G.BurstLevel, 3) do
                                task.spawn(function() TreeRemote:FireServer("damage", tree.Name) end)
                            end
                        end
                    end
                    task.wait(REMOTE_STABILIZER)
                end
            end
        else
            task.wait(0.2)
        end
    end
end)

